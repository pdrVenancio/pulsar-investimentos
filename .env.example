# Local single-machine defaults
PULSAR_ADVERTISED_ADDRESS=localhost
PULSAR_WEB_ADVERTISED_ADDRESS=localhost
PULSAR_URL=pulsar://localhost:6650
PULSAR_ADMIN_URL=http://localhost:8080
VITE_API_BASE_URL=http://localhost:8000
VITE_PULSAR_WS_BASE_URL=ws://localhost:8080
CORS_ORIGINS=http://localhost:3000
KAFKA_BOOTSTRAP=pulsar:9092

# Three-machine example:
# middleware machine DNS/IP: pulsar-host
# backend machine DNS/IP: backend-host
# frontend machine DNS/IP: frontend-host
#
# On middleware machine:
# PULSAR_ADVERTISED_ADDRESS=pulsar-host
# PULSAR_WEB_ADVERTISED_ADDRESS=pulsar-host
#
# On backend machine:
# PULSAR_URL=pulsar://pulsar-host:6650
# PULSAR_ADMIN_URL=http://pulsar-host:8080
# CORS_ORIGINS=http://frontend-host:3000
#
# On frontend machine:
# VITE_API_BASE_URL=http://backend-host:8000
# VITE_PULSAR_WS_BASE_URL=ws://pulsar-host:8080
